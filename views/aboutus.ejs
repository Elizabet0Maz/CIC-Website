    <main>
       <!-- about us hero section -->
        <section class="hero-section about-hero">
            <div class="hero-content">
                <h1>Our Story</h1>
                <p>A curated collection where the soul of tradition meets the spirit of the modern explorer.</p>
            </div>
        </section>


        <!-- combined heritage & heart and curated journey section -->
        <section class="about-combined-section">
            <h2 class="main-grid-title">A Curated Journey</h2>

            <div class="about-combined-flex">
                <div class="about-grid-section">
                    <div class="image-grid">
                        <div class="grid-item"><img src="/Sources/imagesAboutContact/flowersoapimage.png" alt="Traditional flowers and soap"></div>
                        <div class="grid-item"><img src="/Sources/imagesAboutContact/pinkscarimage.png" alt="Handmade pink scarf"></div>
                        <div class="grid-item"><img src="/Sources/imagesAboutContact/earringsonstoneimage.png" alt="Artisan pearl earrings"></div>
                        <div class="grid-item"><img src="/Sources/imagesAboutContact/lavendersoapimage.png" alt="Lavender scented soap"></div>
                    </div>
                </div>

                <div class="heritage-heart-section">
                    <h3 class="section-title">Heritage & Heart</h3>
                    <div class="text-content">
                        <p>
                                Born in the heart of Ajman, Aladdin General Trading was created to be more than a store—it’s a destination.
                                Inspired by the vibrant spirit of the Emirates, we bring together the finest scents, sweets, and handcrafted treasures under one roof.
                            </p>
                            <p>
                                We believe the best gifts have a soul. That’s why we curate a collection where tradition meets modern style.
                                From signature fragrances to handcrafted accessories, every item is handpicked for its unique story and quality.
                            </p>
                            <p>
                                Whether you’re a traveler seeking a piece for our heritage or a local looking for a perfect gift, we make every purchase meaningful.
                                From a small dream to a community favorite, we offer an authentic world of variety that is always welcoming.
                            </p>
                    </div>
                </div>
            </div>
        </section> 

        <!-- tradtional finds section -->
        <section class="traditional-finds-section">
            <div class="traditional-finds__container">
                <div class="finds-text-content">
                    <h3>Traditional Finds</h3>
                    <p>
                        From signature Arabic fragrances to traditional sweets, our collection captures the essence of our culture.
                         Discover handcrafted treasures and unique accessories designed to bring heritage to you.
                    </p>
                    <a href="/shop" class="btn-explore">Explore Collection</a>
                </div>
                <div class="finds-image-wrapper">
                    <img src="/Sources/imagesAboutContact/traditionalfindsimage.png" alt="Traditional Aladdin lamps">
                </div>
            </div>
        </section>
